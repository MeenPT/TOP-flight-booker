<article class="card">
  <div class="card-body">
    <h3 class="h5 card-title"><%= flight.departure_airport.iata %> <i role="presentation" aria-disabled="true" class="bi bi-arrow-right mx-2"></i> <%= flight.arrival_airport.iata %></h3>
    <hr>
    <div class="card-text">
      <div class="hstack">
        <i class="bi bi-calendar-check"></i>
        <time class="ms-2" datetime="<%= flight.depart_at %>"><%= flight.depart_at.strftime("%d/%m/%Y") %></time>
      </div>
    </div>
    <div class="mt-4">
      <%= link_to flight, class: "btn btn-sm btn-outline-secondary" do %>
        Details <i class="bi bi-eye ms-2"></i>
      <% end %>
    </div>
  </div>
</article>